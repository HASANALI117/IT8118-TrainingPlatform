@model IEnumerable<TrainingPlatform.MVC.Models.ViewModels.ClassroomViewModel>
@{ ViewData["Title"] = "Classrooms"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Classrooms</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Classroom</a>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Capacity</th>
            <th>Equipment</th>
            <th>Sessions</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model)
        {
            <tr>
                <td>@room.Name</td>
                <td>@room.Capacity</td>
                <td>@(string.IsNullOrWhiteSpace(room.Equipment) ? "—" : room.Equipment)</td>
                <td>@room.SessionCount</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@room.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete @room.Name?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
