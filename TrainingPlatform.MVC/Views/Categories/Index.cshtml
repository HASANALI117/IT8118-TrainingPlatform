@model IEnumerable<TrainingPlatform.MVC.Models.ViewModels.CategoryViewModel>
@{ ViewData["Title"] = "Categories"; }

<div class="tp-page-header">
    <div>
        <span class="tp-page-eyebrow"><i class="bi bi-tags"></i> Manage</span>
        <h1 class="tp-page-title">Categories</h1>
        <p class="tp-page-subtitle">Organise courses into discoverable groups.</p>
    </div>
    <div class="tp-page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Category
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="tp-empty">
        <i class="bi bi-tags"></i>
        <h4>No categories yet</h4>
        <p>Create your first category to start grouping courses.</p>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Category</a>
    </div>
}
else
{
    <div class="tp-table-card">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th style="width: 140px;">Courses</th>
                    <th class="text-end" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>
                            <div class="d-inline-flex align-items-center gap-2">
                                <span class="tp-icon-circle"><i class="bi bi-tag-fill"></i></span>
                                <span class="fw-semibold">@cat.Name</span>
                            </div>
                        </td>
                        <td><span class="badge bg-primary">@cat.CourseCount</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post" class="d-inline m-0"
                                  onsubmit="return confirm('Delete category @cat.Name?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
