@model IEnumerable<TrainingPlatform.MVC.Models.ViewModels.CourseSessionListItemViewModel>
@{ ViewData["Title"] = "Course Schedule"; }

<div class="tp-page-header">
    <div>
        <span class="tp-page-eyebrow"><i class="bi bi-calendar-event"></i> Manage</span>
        <h1 class="tp-page-title">Course Schedule</h1>
        <p class="tp-page-subtitle">All scheduled sessions. The system prevents instructor and classroom double-booking.</p>
    </div>
    <div class="tp-page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Schedule Session
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="tp-empty">
        <i class="bi bi-calendar-event"></i>
        <h4>No sessions scheduled</h4>
        <p>Schedule your first session to start enrolling trainees.</p>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Schedule Session</a>
    </div>
}
else
{
    <div class="tp-table-card">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Classroom</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Spots</th>
                    <th>Enrolled</th>
                    <th class="text-end" style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    var spotsLeft = s.AvailableSpots - s.EnrollmentCount;
                    var (badgeClass, badgeIcon, badgeText) =
                        spotsLeft <= 0 ? ("bg-danger", "bi-x-circle-fill", "Full") :
                        spotsLeft <= 5 ? ("bg-warning", "bi-exclamation-circle-fill", spotsLeft + " left") :
                        ("bg-success", "bi-check-circle-fill", spotsLeft + " left");
                    <tr>
                        <td><span class="fw-semibold">@s.CourseTitle</span></td>
                        <td class="tp-text-soft">
                            <span class="d-inline-flex align-items-center gap-1"><i class="bi bi-person"></i> @s.InstructorName</span>
                        </td>
                        <td class="tp-text-soft">
                            <span class="d-inline-flex align-items-center gap-1"><i class="bi bi-door-open"></i> @s.ClassroomName</span>
                        </td>
                        <td class="tp-text-soft tp-mono" style="font-size: .9rem;">@s.SessionDate.ToString("dd MMM yyyy")</td>
                        <td class="tp-text-soft tp-mono" style="font-size: .9rem;">@s.StartTime.ToString("hh\\:mm tt")</td>
                        <td>
                            <span class="badge @badgeClass">
                                <i class="bi @badgeIcon"></i> @badgeText
                            </span>
                        </td>
                        <td class="tp-text-soft">@s.EnrollmentCount / @s.AvailableSpots</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline m-0"
                                  onsubmit="return confirm('Delete this session?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
