@model TrainingPlatform.MVC.Models.ViewModels.CourseSessionDetailsViewModel
@{ ViewData["Title"] = "Session Details"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Schedule</a></li>
        <li class="breadcrumb-item active">Session Details</li>
    </ol>
</nav>

<h2>@Model.CourseTitle</h2>
<p class="text-muted">@Model.CourseDescription</p>

<div class="row">
    <div class="col-md-6">
        <ul class="list-group list-group-flush">
            <li class="list-group-item"><strong>Instructor:</strong> @Model.InstructorName</li>
            <li class="list-group-item"><strong>Classroom:</strong> @Model.ClassroomName</li>
            @if (!string.IsNullOrWhiteSpace(Model.ClassroomEquipment))
            {
                <li class="list-group-item"><strong>Equipment:</strong> @Model.ClassroomEquipment</li>
            }
            <li class="list-group-item"><strong>Date:</strong> @Model.SessionDate.ToString("dddd, dd MMMM yyyy")</li>
            <li class="list-group-item"><strong>Start Time:</strong> @Model.StartTime.ToString("hh\\:mm tt")</li>
            <li class="list-group-item">
                <strong>Enrolment:</strong> @Model.EnrollmentCount / @Model.AvailableSpots
                (@(Model.AvailableSpots - Model.EnrollmentCount) spots remaining)
            </li>
        </ul>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to Schedule</a>
</div>
