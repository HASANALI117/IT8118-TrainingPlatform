@{
    ViewData["Title"] = "Home";
    ViewData["FullWidth"] = true;
}

<div class="cd-inner">

    <section class="intro-wrapper">
        <div class="content">
            <img src="~/images/logo-2.png" alt="Certifi" class="cd-logo" />
            <h1>Certifi</h1>
            <p>Modern training operations &mdash; catalog, scheduling, and certificates.</p>
            <ul class="action-list stacked">
                <li><a asp-controller="Courses" asp-action="Index" class="button special wide">Browse Courses</a></li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                            <button type="submit" class="button wide">Log Out</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="Login" class="button wide">Log In</a></li>
                }
            </ul>
        </div>
        <a href="#about">What's inside?</a>
    </section>

    <section id="about" class="about-wrapper style1">
        <header>
            <h2>Run training for<br/>pretty much any program</h2>
            <p>Catalog, sessions, instructors, certifications &mdash; coordinated end to end.<br/>Built for trainees, instructors, and coordinators.</p>
        </header>
        <div class="carousel">
            <div class="reel">
                @for (int i = 0; i < 2; i++)
                {
                    <a asp-controller="Courses" asp-action="Index">
                        <div class="card-inner">
                            <i class="bi bi-collection"></i>
                            <h3>Course Catalog</h3>
                            <p>Curated courses with prerequisites, fees, and capacity.</p>
                        </div>
                    </a>
                    <a asp-controller="CourseSessions" asp-action="Index">
                        <div class="card-inner">
                            <i class="bi bi-calendar-event"></i>
                            <h3>Scheduling</h3>
                            <p>Sessions with automatic conflict checks for rooms and instructors.</p>
                        </div>
                    </a>
                    <a asp-controller="Instructors" asp-action="Index">
                        <div class="card-inner">
                            <i class="bi bi-person-badge"></i>
                            <h3>Instructors</h3>
                            <p>Expertise areas, bios, and session loads at a glance.</p>
                        </div>
                    </a>
                    <a asp-controller="Classrooms" asp-action="Index">
                        <div class="card-inner">
                            <i class="bi bi-door-open"></i>
                            <h3>Classrooms</h3>
                            <p>Capacity and equipment per room, never double-booked.</p>
                        </div>
                    </a>
                    <a asp-controller="Certification" asp-action="Lookup">
                        <div class="card-inner">
                            <i class="bi bi-patch-check"></i>
                            <h3>Certificate Lookup</h3>
                            <p>Public verification &mdash; no login required, confirm in seconds.</p>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>

    <section class="highlights-wrapper">
        <section>
            <div class="pic"><div class="highlight"><i class="bi bi-mortarboard"></i></div></div>
            <div class="content">
                <h2>Trainees</h2>
                <p>Enroll in sessions, track certification progress, and view payments and outstanding balances &mdash; everything you need to plan your learning path.</p>
            </div>
        </section>
        <section>
            <div class="pic"><div class="highlight"><i class="bi bi-easel"></i></div></div>
            <div class="content">
                <h2>Instructors</h2>
                <p>See assigned sessions, attendance, and record pass/fail assessment results per trainee. Every credential, every track, every classroom.</p>
            </div>
        </section>
        <section>
            <div class="pic"><div class="highlight"><i class="bi bi-sliders"></i></div></div>
            <div class="content">
                <h2>Coordinators</h2>
                <p>Full control &mdash; users, courses, schedules, certifications, payments, and operational reporting in one workspace.</p>
            </div>
        </section>
    </section>

    <section class="pro-wrapper style1">
        <header>
            <h2>Everything you need</h2>
            <p>Core features ready out of the box &mdash; from prerequisite validation<br/>to real-time enrollment counters and certification tracks.</p>
        </header>
        <div class="content">
            <ul class="pro-features">
                <li>
                    <h3>Prerequisite Validation</h3>
                    <p>Enrollment checks confirm the trainee has completed required prior courses before confirming a seat.</p>
                </li>
                <li>
                    <h3>Capacity Limits</h3>
                    <p>Sessions auto-reject enrollment when the classroom is full &mdash; with a live counter powered by SignalR.</p>
                </li>
                <li>
                    <h3>No Double-Booking</h3>
                    <p>Instructor and classroom conflicts are detected and blocked before a session is saved.</p>
                </li>
                <li>
                    <h3>Certification Tracks</h3>
                    <p>Auto-mark trainees Eligible the moment every course in a track is passed &mdash; no manual checks.</p>
                </li>
                <li>
                    <h3>Payment Tracking</h3>
                    <p>Outstanding balance per enrollment with automatic overdue flagging based on due dates.</p>
                </li>
                <li>
                    <h3>Operational Reports</h3>
                    <p>Enrollment, instructor workload, completion rates, and revenue dashboards for coordinators.</p>
                </li>
            </ul>
            <div class="pro-cta">
                <p><strong>Ready to start?</strong> Pick a path below &mdash; no signup needed to verify a certificate.</p>
                <ul class="action-list stacked">
                    <li><a asp-controller="Courses" asp-action="Index" class="button special wide">Browse Courses</a></li>
                </ul>
            </div>
        </div>
    </section>

    <section class="cta-wrapper style2">
        <h2>Sound good?</h2>
        <p>Click below to get started.</p>
        <ul class="action-list stacked">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li><a asp-controller="Courses" asp-action="Index" class="button special wide">Browse Courses</a></li>
            }
            else
            {
                <li><a asp-controller="Account" asp-action="Register" class="button special wide">Get Started</a></li>
                <li><a asp-controller="Account" asp-action="Login" class="button wide">Log In</a></li>
            }
        </ul>
    </section>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script>
        (function () {
            if (typeof gsap === 'undefined') return;
            var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (reduce) return;
            gsap.registerPlugin(ScrollTrigger);

            // --- Onload hero entrance (carrd-like fade + slight rise) ---
            var heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
            heroTl
                .from('.intro-wrapper .content > svg, .intro-wrapper .content > .cd-logo', { y: -20, opacity: 0, scale: .85, duration: 1 })
                .from('.intro-wrapper .content h1',    { y: 30, opacity: 0, duration: .8 }, '-=.55')
                .from('.intro-wrapper .content p',     { y: 20, opacity: 0, duration: .7 }, '-=.55')
                .from('.intro-wrapper .action-list li',{ y: 18, opacity: 0, stagger: .12, duration: .55 }, '-=.45')
                .from('.intro-wrapper a[href="#about"]',{ y: 14, opacity: 0, duration: .55 }, '-=.25');

            // Subtle logo float
            gsap.to('.intro-wrapper .content > svg, .intro-wrapper .content > .cd-logo', {
                y: -8, duration: 2.6, ease: 'sine.inOut', yoyo: true, repeat: -1
            });

            // --- ScrollTrigger: each section rises + fades on enter ---
            gsap.utils.toArray('.cd-inner > section:not(.intro-wrapper)').forEach(function (sec) {
                gsap.from(sec, {
                    y: 50, opacity: 0, duration: 1, ease: 'power3.out',
                    scrollTrigger: { trigger: sec, start: 'top 85%', once: true }
                });
            });

            // Highlight rows alternate side reveal
            gsap.utils.toArray('.highlights-wrapper > section').forEach(function (row, i) {
                var fromX = (i % 2 === 0) ? -60 : 60;
                gsap.from(row, {
                    x: fromX, opacity: 0, duration: .9, ease: 'power3.out',
                    scrollTrigger: { trigger: row, start: 'top 82%', once: true }
                });
            });

            // Pro feature bullets stagger
            gsap.utils.toArray('.pro-features li').forEach(function (li, i) {
                gsap.from(li, {
                    y: 30, opacity: 0, duration: .6, ease: 'power2.out',
                    delay: (i % 2) * 0.08,
                    scrollTrigger: { trigger: li, start: 'top 88%', once: true }
                });
            });
        })();
    </script>
}
