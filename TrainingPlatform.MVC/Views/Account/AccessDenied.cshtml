@{ ViewData["Title"] = "Access Denied"; }

<div class="tp-auth-shell">
    <div class="tp-auth-card text-center">
        <div class="tp-auth-mark" style="background: linear-gradient(135deg, #dc2626 0%, #f97316 100%);">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h1 class="tp-auth-title">Access denied</h1>
        <p class="tp-auth-sub">You don't have permission to view this page. If you believe this is a mistake, please contact a Training Coordinator.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary w-100">
            <i class="bi bi-house"></i> Go Home
        </a>
    </div>
</div>
