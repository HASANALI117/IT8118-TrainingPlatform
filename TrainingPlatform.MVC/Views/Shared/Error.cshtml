@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="tp-auth-shell">
    <div class="tp-auth-card text-center">
        <div class="tp-auth-mark" style="background: linear-gradient(135deg, #dc2626 0%, #f59e0b 100%);">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h1 class="tp-auth-title">Something went wrong</h1>
        <p class="tp-auth-sub">An error occurred while processing your request. Please try again.</p>

        @if (Model.ShowRequestId)
        {
            <p class="tp-text-muted mb-3" style="font-size: .85rem;">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary w-100">
            <i class="bi bi-house"></i> Back to Home
        </a>

        <hr class="tp-divider" />

        <details class="text-start">
            <summary class="tp-text-soft" style="cursor: pointer; font-weight: 500;">Developer details</summary>
            <p class="tp-text-muted mt-3" style="font-size: .85rem;">
                Swap to the <strong>Development</strong> environment to see detailed error information.
                Don't enable Development for deployed apps — it can expose sensitive data.
                Set <code>ASPNETCORE_ENVIRONMENT</code> to <code>Development</code> and restart the app.
            </p>
        </details>
    </div>
</div>
