@model TrainingPlatform.MVC.Models.ViewModels.InstructorFormViewModel
@{ ViewData["Title"] = "Edit Instructor"; }

<h2>Edit Instructor Profile</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="ExpertiseAreas" class="form-label"></label>
                <input asp-for="ExpertiseAreas" class="form-control" />
                <span asp-validation-for="ExpertiseAreas" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Bio" class="form-label"></label>
                <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
