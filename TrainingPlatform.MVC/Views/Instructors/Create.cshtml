@model TrainingPlatform.MVC.Models.ViewModels.InstructorFormViewModel
@{ ViewData["Title"] = "Add Instructor"; }

<div class="tp-page-header">
    <div>
        <span class="tp-page-eyebrow"><i class="bi bi-plus-circle"></i> Manage</span>
        <h1 class="tp-page-title">Add Instructor</h1>
        <p class="tp-page-subtitle">Promote an existing user account into an instructor profile.</p>
    </div>
</div>

<div class="row">
    <div class="col-xl-8">
        <div class="tp-form-card">
            <form asp-action="Create" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-circle"></i><div class="flex-grow-1"></div>
                </div>

                <div class="mb-3">
                    <label asp-for="UserId" class="form-label"></label>
                    <select asp-for="UserId" asp-items="Model.AvailableUsers" class="form-select">
                        <option value="">-- Select User --</option>
                    </select>
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ExpertiseAreas" class="form-label"></label>
                    <input asp-for="ExpertiseAreas" class="form-control" placeholder="e.g. Networking, Security, Cloud" />
                    <span asp-validation-for="ExpertiseAreas" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Bio" class="form-label"></label>
                    <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Brief professional bio..."></textarea>
                </div>

                <div class="tp-form-actions">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle"></i> Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
