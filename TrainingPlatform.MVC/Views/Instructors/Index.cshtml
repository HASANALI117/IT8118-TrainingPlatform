@model IEnumerable<TrainingPlatform.MVC.Models.ViewModels.InstructorListItemViewModel>
@{ ViewData["Title"] = "Instructors"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Instructors</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Instructor</a>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Expertise</th>
            <th>Sessions</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model)
        {
            <tr>
                <td>@i.FullName</td>
                <td>@i.Email</td>
                <td>@i.ExpertiseAreas</td>
                <td>@i.SessionCount</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    <a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>
